# Backend API URL
# Para desarrollo local: http://localhost:3000/api
# Para producción: https://pokecollect-backend.onrender.com/api
VITE_API_BASE=https://pokecollect-backend.onrender.com/api

# Supabase Configuration
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anonima_de_supabase
VITE_SUPABASE_SERVICE_KEY=tu_clave_de_servicio_de_supabase

# Pokemon TCG API Key (opcional)
# VITE_POKEMON_TCG_API_KEY=tu_clave_pokemon_tcg_api

# Brevo (Sendinblue) API Key para envío de emails
# Obtén tu clave API en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=tu_clave_brevo_api

# IMPORTANTE PARA NETLIFY:
# 1. Configura VITE_API_BASE=https://pokecollect-backend.onrender.com/api
# 2. El backend está desplegado en Render y debe estar accesible
# 3. Todas las variables que empiecen con VITE_ estarán disponibles en el frontend
# 4. Las variables sin VITE_ son solo para el backend (como BREVO_API_KEY)